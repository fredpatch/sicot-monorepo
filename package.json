{
  "name": "sicot",
  "version": "1.0.0",
  "description": "Système Intégré de Coopération Internationale et de Traduction – ANAC Gabon",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/server && npm run build --workspace=packages/client",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "db:generate": "npm run db:generate --workspace=packages/server",
    "db:migrate": "npm run db:migrate --workspace=packages/server",
    "db:studio": "npm run db:studio --workspace=packages/server"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0"
  }
}
