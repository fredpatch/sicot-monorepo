# ── Base de données ────────────────────────────────────────
DATABASE_URL=postgresql://sicot_user:sicot_pass@localhost:5432/sicot_db

# ── Serveur ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MINIMUM_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_IN_PRODUCTION_MINIMUM_32_CHARS_REFRESH
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP (serveur mail ANAC) ───────────────────────────────
SMTP_HOST=mail.anac.ga
SMTP_PORT=587
SMTP_USER=sicot@anac.ga
SMTP_PASS=CHANGE_ME
SMTP_FROM=SICOT <sicot@anac.ga>

# ── OCR - Tesseract (microservice Python) ──────────────────
OCR_SERVICE_URL=http://localhost:5001

# ── Traduction IA ──────────────────────────────────────────
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=

# DeepL (fallback, désactivé par défaut)
DEEPL_ENABLED=false
